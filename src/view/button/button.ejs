<% title = '按钮'; %>
<%- include('../compoents/default/_header.ejs'); %>
<style>
    h3,
    p {
        /*text-align: center;*/
    }
</style>
<div class="margin">
    <div class="box">
        <div class="box-header with-border">按钮</div>
        <div class="box-body">
            <!--            <h3>lg按钮</h3>-->
            <p>
                <button class="ez-btn ez-btn-lg ez-btn-primary">大按钮</button>
                <button class="ez-btn ez-btn-primary">默认按钮</button>
                <button class="ez-btn ez-btn-sm ez-btn-primary">小一号按钮</button>
                <button class="ez-btn ez-btn-xs ez-btn-primary">最小按钮</button>
            </p>
            <p>
                <button class="ez-btn">.ez-btn</button>
                <a class="ez-btn ez-btn-primary">.ez-btn-primary</a>
                <button class="ez-btn ez-btn-secondary">.ez-btn-secondary</button>
                <a class="ez-btn ez-btn-success">.ez-btn-success</a>
                <button class="ez-btn ez-btn-warning">.ez-btn-warning</button>
                <a class="ez-btn ez-btn-danger">.ez-btn-danger</a>
                <button class="ez-btn ez-btn-link">.ez-btn-link</button>
                <a class="ez-btn ez-btn-disabled">.ez-btn-disabled</a>
            </p>
            <p>
                <button class="ez-btn ez-btn-primary">直角</button>
                <button class="ez-btn ez-btn-radius ez-btn-primary">圆角 .btn-radius</button>
                <button class="ez-btn ez-btn-round ez-btn-primary">椭圆 .btn-round</button>
            </p>
            <p>
                <button class="ez-btn ez-btn-full ez-btn-radius ez-btn-success">块.btn-full</button>
            </p>
            <p>
                <button class="ez-btn ez-btn-primary">
                    <i class="remixicon-home-4-line"></i> 添加图标
                </button>
                <button class="ez-btn ez-btn-primary">
                    <i class="remixicon-wechat-2-fill"></i> 微信
                </button>
                <button class="ez-btn ez-btn-primary ez-btn-xs">
                    <i class="remixicon-wechat-2-line"></i> 微信
                </button>
                <button class="ez-btn ez-btn-primary">
                    <i class="remixicon-settings-2-line"></i> 设置图标
                </button>
            </p>
            <p>
                <span class="ez-btn-group">
                    <button class="ez-btn">全选</button>
                    <button class="ez-btn">反选</button>
                    <button class="ez-btn">取消</button>
                </span>
                <span class="ez-btn-group">
                    <button class="ez-btn ez-btn-primary">全选</button>
                    <button class="ez-btn ez-btn-primary">取消</button>
                </span>
                <span class="ez-btn-group">
                    <button class="ez-btn ez-btn-sm ez-btn-secondary">全选</button>
                    <button class="ez-btn ez-btn-sm ez-btn-secondary">取消</button>
                </span>
                <span class="ez-btn-group ez-btn-group-radius">
                    <button class="ez-btn ez-btn-success">全选</button>
                    <button class="ez-btn ez-btn-success">反选哈哈哈</button>
                    <button class="ez-btn ez-btn-success">取消</button>
                </span>
                <span class="ez-btn-group ez-btn-group-round">
                    <button class="ez-btn ez-btn-xs ez-btn-warning">确定</button>
                    <button class="ez-btn ez-btn-xs ez-btn-warning">取消</button>
                </span>
                <span class="ez-btn-group ez-btn-group-round">
                    <button class="ez-btn ez-btn-primary">确定</button>
                    <button class="ez-btn">取消</button>
                </span>
                <span class="ez-btn-group ez-btn-group-full">
                    <button class="ez-btn ez-btn-danger">全选</button>
                    <button class="ez-btn ez-btn-danger">内容长度不一样?</button>
                    <button class="ez-btn ez-btn-danger">是否均分</button>
                </span>
            </p>
            <h3>浅色系 @todo</h3>
            <h3>带边框 @todo</h3>
