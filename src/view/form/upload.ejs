<% title = '表单'; %>
<%- include('../compoents/default/_header.ejs'); %>

<h2>一行</h2>
<div class="ez-form ez-form-inline ez-form-full">
    <%- include('./_upload.ejs', {id: 'play_1'});%>
</div>
<hr>

<h2>分行</h2>

<div class="ez-form ez-form-sm">
    <%- include('./_upload.ejs', {id: 'play_2'});%>
</div>

<script>
    $('.form-sm').find('.btn').addClass('btn-sm');  //sm模式下按钮也调小

    $('.upload').last().data('multiple', 'true');

    $('.upload').ez_form_upload({
        url: '/data/upload.json'
    });

    $('.ez-form-control').addClass('ez-cursor-search').on('click', '.ez-form-label', function () {
        console.log('view image');
    });

    $('.play').ez_form_play();
</script>


