<form action="">
    <div class="ez-form-row">
        <div class="ez-form-title">文件上传</div>
        <div class="ez-form-content">
            <div class="ez-form-flex">
                <div class="ez-form-control">
                    未选择任何文件
                </div>
                <span class="upload ez-form-addon">选择文件</span>
                <select class="ez-form-upload-field" name="" multiple>
                    <option value="/data/selected.mp3">selected.mp3</option>
                </select>
            </div>
        </div>
    </div>
    <div class="ez-form-row">
        <div class="ez-form-title">单选</div>
        <div class="ez-form-content">
            <div class="ez-form-flex">
                <div class="ez-form-control">
                    <span class="ez-form-label">/files/2012-12-12/12/12/e36a6b89ae2adf820058e5f1b2a42f826d3f4a7.jpg <i class="ez-form-label-remove remixicon-close-fill"></i></span>
                </div>
                <span class="ez-form-addon"><i class="remixicon-close-line"></i></span>
                <span class="ez-form-addon"><i class="remixicon-play-fill"></i></span>
                <span class="ez-form-addon">选择文件</span>
            </div>
        </div>
    </div>
    <div class="ez-form-row">
        <div class="ez-form-title">多选</div>
        <div class="ez-form-content">
            <div class="ez-form-flex">
                <div class="ez-form-control">
                    <% for(var i = 0; i < 1; i++){ %>
                        <span class="ez-form-label">绑定电话缴费凭证.png <i class="ez-form-label-remove remixicon-close-fill"></i></span>
                        <span class="ez-form-label">营业执照.jpg <i class="ez-form-label-remove remixicon-close-fill"></i></span>
                        <span class="ez-form-label">彩铃音.mp3 <i class="ez-form-label-remove remixicon-close-fill"></i></span>
                    <% } %>
                </div>
                <span class="ez-form-addon">选择文件</span>
            </div>
        </div>
    </div>

    <div class="ez-form-row">
        <div class="ez-form-title"></div>
        <div class="ez-form-content">
            <button class="ez-btn ez-btn-primary">提交</button>
            <button class="ez-btn">取消</button>
        </div>
    </div>

</form>

