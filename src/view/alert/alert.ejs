<% title = 'alert'; %>
<%- include('../compoents/default/_header.ejs'); %>
<% var type = ['', 'primary', 'secondary', 'success', 'warning', 'danger']; %>
<div class="margin">
    <div class="box">
        <div class="box-body">
            <% for(var i = 0; i < type.length; i++){ %>
                <div class="ez-alert <%- type[i] === '' ? '' : 'ez-alert-' + type[i] %>">
                    <div class="ez-alert-title">标题</div>
                    <div class="ez-alert-content">这是一句绕口令：黑灰化肥会挥发发灰黑化肥挥发；灰黑化肥会挥发发黑灰化肥发挥。 黑灰化肥会挥发发灰黑化肥黑灰挥发化为灰……</div>
                </div>
